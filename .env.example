# ============================================================
# Nutrition Label Analyzer – Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#   cp .env.example .env

# --- PostgreSQL -------------------------------------------
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nutrition_label_db

# Or provide a full connection URL (takes precedence):
# DATABASE_URL=postgresql://postgres:your_password_here@localhost:5432/nutrition_label_db

# --- Google Cloud Vision ----------------------------------
# Path to your GCP service-account JSON key file.
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json
